# Generated files that should be committed
# Note: docs/ directory is committed for GitHub Pages, but we exclude certain temporary files

# Temporary files
*.tmp
*.temp
/temp/
/tmp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js (if used for local development)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if used for local development)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# Logs
logs
*.log

# Backup directory (contains markdown backups - these are committed)
# backup/ - keep this committed as it contains content

# Custom assets are preserved and should be committed
# docs/assets/ - keep this committed

# Generated HTML files are committed for GitHub Pages
# docs/*.html - keep these committed
# docs/post/ - keep this committed
# docs/rss.xml - keep this committed